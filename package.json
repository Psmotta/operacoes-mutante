{
  "name": "operacoes-mutante-lab",
  "version": "1.0.0",
  "description": "Projeto base para o trabalho de Teste de Mutação com StrykerJS.",
  "main": "src/operacoes.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:cov": "jest --coverage",
    "coverage": "jest --coverage"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.2",
    "@stryker-mutator/core": "^9.3.0",
    "@stryker-mutator/jest-runner": "^9.3.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageProvider": "v8",
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  }
}
